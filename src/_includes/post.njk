---
layout: base.njk
---

<article class="page-article section-reveal">
  <a class="back-link" href="/#posts">Back to home</a>
  <header class="article-header">
    <span class="section-label">Post</span>
    <h1>{{ title }}</h1>
    <div class="item-meta article-meta">
      <span>{{ page.date | date("MMMM d, yyyy") }}</span>
      <span>{{ content | readTime }} min read</span>
      <span>{{ author or site.title }}</span>
    </div>
  </header>

  <div class="article-body">
    {{ content | safe }}
  </div>

  <div class="article-footer">
    <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
  </div>
</article>
