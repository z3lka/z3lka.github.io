---
layout: "base.njk"
--- 

{% block content %}
  <article class="post">
    <h1>{{ title }}</h1>
    <p class="post-meta">
      {{ page.date | date("MMMM d, yyyy") }} &middot;
      {{ content | readTime }} min read &middot; By
      <b>{{ author }}</b>
    </p>
    {{ content | safe }}
    <p style="font-size: 0.9rem;">Got thoughts?
      <a href="mailto:thedeepblueseek@gmail.com">
        Reach out to me anytime!
      </a>
    </p>
  </article>
{% endblock %}