<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{% if title and title != site.title %}{{ title | safe }} · {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    <meta name="description" content="{{ description or site.description }}">
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; img-src 'self' data:; style-src 'self' https://fonts.googleapis.com https://unpkg.com; font-src https://fonts.gstatic.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'">
    <meta name="referrer" content="strict-origin-when-cross-origin">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#182127">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;700&display=swap">
    <link rel="stylesheet" href="https://unpkg.com/prismjs@1.29.0/themes/prism-tomorrow.min.css">
    <link rel="stylesheet" href="/css/main.css">
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header section-reveal">
        <a class="brand" href="/">z3lka</a>
        <nav class="site-nav" aria-label="Primary">
          <a href="/#about" {% if page.url == "/" %}aria-current="page"{% endif %}>About</a>
          <a href="/#projects">Projects</a>
          {% if collections.notes.length %}
            <a href="/#notes">Notes</a>
          {% endif %}
          {% if collections.posts.length %}
            <a href="/#posts">Posts</a>
          {% endif %}
          {% if collections.log.length %}
            <a href="/#updates">Updates</a>
          {% endif %}
        </nav>
      </header>
      <main class="site-main">
        {{ content | safe }}
      </main>
      {% include "footer.njk" %}
    </div>
  </body>
</html>
